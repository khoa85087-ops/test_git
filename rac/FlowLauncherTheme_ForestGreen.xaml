<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

  <!-- Base -->
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="pack://application:,,,/Themes/Base.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- Layout -->
  <Thickness x:Key="ResultMargin">0 0 0 2</Thickness>

  <!-- 🔤 Font Inter (cùng thư mục với file .xaml này) -->
  <FontFamily x:Key="InterFont">./Inter-VariableFont_opsz,wght.ttf#Inter</FontFamily>

  <!-- 🎨 Forest Green Theme (Xanh Lá + Tím + Trắng) -->
  <SolidColorBrush x:Key="ItemSelectedBackgroundColor">#2ECC71</SolidColorBrush> <!-- Fresh Green Primary -->
  <SolidColorBrush x:Key="BorderBrushColor">#1A3D2A</SolidColorBrush> <!-- Dark Green Border -->
  <SolidColorBrush x:Key="DefaultForeground">#D4F5E9</SolidColorBrush> <!-- Light Mint Text -->
  
  <!-- Background: Deep Dark Green -->
  <SolidColorBrush x:Key="WindowBackgroundColor">#0A1410</SolidColorBrush>
  
  <!-- Accents: Green & Purple variations -->
  <SolidColorBrush x:Key="CaretBrushColor">#BB86FC</SolidColorBrush> <!-- Purple Caret -->
  <SolidColorBrush x:Key="SelectionBrushColor">#1DB679</SolidColorBrush> <!-- Dark Green Select -->
  <SolidColorBrush x:Key="SubtleForeground">#4ECDC4</SolidColorBrush> <!-- Teal Text -->
  <SolidColorBrush x:Key="SelectedSubtle">#9D7FFF</SolidColorBrush> <!-- Light Purple Selected -->

  <!-- 🪟 Window -->
  <Style x:Key="WindowStyle"
         BasedOn="{StaticResource BaseWindowStyle}"
         TargetType="{x:Type Window}">
    <Setter Property="Width"       Value="820"/>
    <Setter Property="Height"      Value="560"/>
    <Setter Property="MinWidth"    Value="680"/>
    <Setter Property="FontFamily"  Value="{StaticResource InterFont}"/>
  </Style>

  <Style x:Key="WindowBorderStyle"
         BasedOn="{StaticResource BaseWindowBorderStyle}"
         TargetType="{x:Type Border}">
    <Setter Property="Background"      Value="{StaticResource WindowBackgroundColor}"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="BorderBrush"     Value="#2ECC71"/>
    <Setter Property="CornerRadius"    Value="16"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect Color="#2ECC71"
                          BlurRadius="50"
                          ShadowDepth="0"
                          Opacity="0.25"/>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- 🔤 Input -->
  <Style x:Key="QueryBoxStyle"
         BasedOn="{StaticResource BaseQueryBoxStyle}"
         TargetType="{x:Type TextBox}">
    <Setter Property="Foreground"     Value="#D4F5E9"/>
    <Setter Property="CaretBrush"     Value="{StaticResource CaretBrushColor}"/>
    <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrushColor}"/>
    <Setter Property="FontFamily"     Value="{StaticResource InterFont}"/>
    <Setter Property="FontSize"       Value="22"/>
    <Setter Property="FontWeight"     Value="SemiBold"/>
  </Style>

  <Style x:Key="QuerySuggestionBoxStyle"
         BasedOn="{StaticResource BaseQuerySuggestionBoxStyle}"
         TargetType="{x:Type TextBox}">
    <Setter Property="Foreground" Value="{StaticResource SubtleForeground}"/>
    <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
    <Setter Property="FontSize"   Value="22"/>
  </Style>

  <!-- 📄 Result -->
  <Style x:Key="ItemTitleStyle"
         BasedOn="{StaticResource BaseItemTitleStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#4ECDC4"/>
    <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="FontWeight" Value="Medium"/>
  </Style>

  <Style x:Key="ItemSubTitleStyle"
         BasedOn="{StaticResource BaseItemSubTitleStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#95E1D3"/>
    <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

  <Style x:Key="ItemTitleSelectedStyle"
         BasedOn="{StaticResource BaseItemTitleSelectedStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style x:Key="ItemSubTitleSelectedStyle"
         BasedOn="{StaticResource BaseItemSubTitleSelectedStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#9D7FFF"/>
    <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

  <!-- ✨ Scrollbar Thumb - Green Fresh -->
  <Style x:Key="ThumbStyle"
         BasedOn="{StaticResource BaseThumbStyle}"
         TargetType="{x:Type Thumb}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Thumb}">
          <Border Background="#2ECC71"
                  CornerRadius="6"
                  Margin="2 0"
                  Opacity="0.7"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
