<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

  <!-- Base -->
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="pack://application:,,,/Themes/Base.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- Layout -->
  <Thickness x:Key="ResultMargin">0 0 0 2</Thickness>

  <!-- 🎨 Colors -->
  <SolidColorBrush x:Key="ItemSelectedBackgroundColor">#6E56CF</SolidColorBrush>
  <SolidColorBrush x:Key="BorderBrushColor">#2E2E4A</SolidColorBrush>
  <SolidColorBrush x:Key="DefaultForeground">#E8E8F0</SolidColorBrush>

  <!-- 🪟 Window -->
  <Style x:Key="WindowStyle"
         BasedOn="{StaticResource BaseWindowStyle}"
         TargetType="{x:Type Window}">
    <Setter Property="Width"    Value="820"/>
    <Setter Property="Height"   Value="560"/>
    <Setter Property="MinWidth" Value="680"/>
  </Style>

  <Style x:Key="WindowBorderStyle"
         BasedOn="{StaticResource BaseWindowBorderStyle}"
         TargetType="{x:Type Border}">
    <Setter Property="Background"      Value="#1A1A2E"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush"     Value="#2E2E4A"/>
    <Setter Property="CornerRadius"    Value="14"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect Color="#000000"
                          BlurRadius="40"
                          ShadowDepth="8"
                          Opacity="0.6"/>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- 🔤 Input -->
  <Style x:Key="QueryBoxStyle"
         BasedOn="{StaticResource BaseQueryBoxStyle}"
         TargetType="{x:Type TextBox}">
    <Setter Property="Foreground"     Value="#FFFFFF"/>
    <Setter Property="CaretBrush"     Value="#7ECFEF"/>
    <Setter Property="SelectionBrush" Value="#6E56CF"/>
    <Setter Property="FontSize"       Value="22"/>
    <Setter Property="FontWeight"     Value="SemiBold"/>
  </Style>

  <Style x:Key="QuerySuggestionBoxStyle"
         BasedOn="{StaticResource BaseQuerySuggestionBoxStyle}"
         TargetType="{x:Type TextBox}">
    <Setter Property="Foreground" Value="#555570"/>
    <Setter Property="FontSize"   Value="22"/>
  </Style>

  <!-- 📄 Result -->
  <Style x:Key="ItemTitleStyle"
         BasedOn="{StaticResource BaseItemTitleStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#E8E8F0"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="FontWeight" Value="Medium"/>
  </Style>

  <Style x:Key="ItemSubTitleStyle"
         BasedOn="{StaticResource BaseItemSubTitleStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#7878A0"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

  <Style x:Key="ItemTitleSelectedStyle"
         BasedOn="{StaticResource BaseItemTitleSelectedStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style x:Key="ItemSubTitleSelectedStyle"
         BasedOn="{StaticResource BaseItemSubTitleSelectedStyle}"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground" Value="#C0AAFF"/>
    <Setter Property="FontSize"   Value="12"/>
  </Style>

<!-- ✨ Scrollbar hoàn toàn ẩn -->
<Style x:Key="ScrollBarStyle"
       BasedOn="{StaticResource BaseScrollBarStyle}"
       TargetType="{x:Type ScrollBar}">
    <Setter Property="Width"   Value="0"/>
    <Setter Property="Opacity" Value="0"/>
</Style>
  
      <!-- Preview Panel -->
   <!-- Preview title -->
<Style
    x:Key="PreviewItemTitleStyle"
    BasedOn="{StaticResource BasePreviewItemTitleStyle}"
    TargetType="{x:Type TextBlock}">

    <!-- làm chữ trong suốt thay vì xóa control -->
    <Setter Property="Foreground" Value="Transparent"/>

    <!-- giữ chiều cao nhỏ -->
    <Setter Property="FontSize" Value="1"/>
    <Setter Property="Margin" Value="0"/>
</Style>


<!-- Preview icon -->
<Style
    x:Key="PreviewGlyph"
    BasedOn="{StaticResource BasePreviewGlyph}"
    TargetType="{x:Type TextBlock}">

    <Setter Property="Foreground" Value="#7ECFEF"/>

    <!-- TO HƠN -->
    <Setter Property="FontSize" Value="140"/>

    <!-- khung lớn hơn -->
    <Setter Property="Width" Value="180"/>
    <Setter Property="Height" Value="180"/>

    <!-- canh giữa -->
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>

    <!-- đẩy xuống giữa preview -->
    <Setter Property="Margin" Value="0 40 0 30"/>

</Style>
<!-- Preview image -->

 <!-- Preview image -->
<Style TargetType="{x:Type Image}">

    <Setter Property="Stretch" Value="Uniform"/>

    <!-- canh giữa thật -->
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>

    <!-- scale lớn hơn chút -->
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

    <Setter Property="RenderTransform">
        <Setter.Value>
            <ScaleTransform ScaleX="1.9" ScaleY="1.9"/>
        </Setter.Value>
    </Setter>

    <!-- canh giữa preview -->
    <Setter Property="Margin" Value="0 70 0 70"/>

</Style>

</ResourceDictionary>